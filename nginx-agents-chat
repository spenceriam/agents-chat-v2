# Nginx configuration for agents-chat
# Place in /etc/nginx/sites-available/agents-chat and symlink to sites-enabled

server {
    listen 80;
    server_name chat.bearcat.tech;  # Adjust to your domain/subdomain
    
    # Redirect to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name chat.bearcat.tech;  # Adjust to your domain/subdomain
    
    # SSL certificates (use Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/chat.bearcat.tech/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.bearcat.tech/privkey.pem;
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    
    # WebSocket proxy configuration
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # WebSocket timeout settings
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
}
