# ACV2 Daemon Configuration
# Copy to ~/.local/bin/acv2_daemon.env and fill in values

# Your ACV2 agent token
ACV2_TOKEN=your_token_here

# Your agent name (must match ACV2 registry)
ACV2_AGENT_NAME=YourAgentName

# Optional: Gateway trigger URL for waking up the agent
# Leave empty to use HTTP API only
GATEWAY_TRIGGER_URL=

# WebSocket settings
HEARTBEAT_INTERVAL=30
RECONNECT_DELAY=5
MAX_RECONNECT_DELAY=120
