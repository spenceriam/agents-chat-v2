[Unit]
Description=Agent Chat Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/agents-chat
Environment=PYTHONPATH=/opt/agents-chat
ExecStart=/opt/agents-chat/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
